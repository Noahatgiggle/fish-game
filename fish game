enemy.y - camera.y,
12,
0,
Math.PI * 2
);

ctx.fill();

}

}

function drawBosses(){

for(let boss of bosses){

ctx.fillStyle = "purple";

ctx.beginPath();

ctx.arc(
boss.x - camera.x,
boss.y - camera.y,
30,
0,
Math.PI * 2
);

ctx.fill();

ctx.fillStyle = "white";

ctx.fillRect(
boss.x - camera.x - 40,
boss.y - camera.y - 50,
80,
8
);

ctx.fillStyle = "lime";

ctx.fillRect(
boss.x - camera.x - 40,
boss.y - camera.y - 50,
80 * (boss.hp / boss.maxHp),
8
);

ctx.fillStyle = "white";

ctx.font = "12px Arial";

ctx.fillText(
boss.name,
boss.x - camera.x - 40,
boss.y - camera.y - 60
);

}

}

function drawPlayer(){

ctx.fillStyle = "yellow";

ctx.beginPath();

ctx.arc(
player.x - camera.x,
player.y - camera.y,
18,
0,
Math.PI * 2
);

ctx.fill();

ctx.fillStyle = "black";

ctx.beginPath();

ctx.arc(
player.x - camera.x + 5,
player.y - camera.y - 4,
2,
0,
Math.PI * 2
);

ctx.fill();

}

// =========================
// COLLECTIONS
// =========================

function collectCoins(){

for(
let i = coins.length - 1;
i >= 0;
i--
){

const coin = coins[i];

const distance =
Math.hypot(
player.x - coin.x,
player.y - coin.y
);

if(distance < 25){

player.coins += coin.value;

player.score =
(player.score || 0) +
coin.value;

gainXP(
coin.value * 2
);

updateQuest(1,1);

coins.splice(i,1);

}

}

}

function collectLoot(){

for(
let i = lootDrops.length - 1;
i >= 0;
i--
){

const loot = lootDrops[i];

const distance =
Math.hypot(
player.x - loot.x,
player.y - loot.y
);

if(distance < 30){

player.inventory.push(
loot.type
);

lootDrops.splice(i,1);

}

}

}

// =========================
// UI
// =========================

function updateUI(){

document.getElementById(
"ui"
).innerHTML =

"🐟 Fish Adventure X10<br>" +

"Level: " + player.level +
" | XP: " + player.xp + "<br>" +

"HP: " + player.hp +
"/" + player.maxHp + "<br>" +

"Coins: " + player.coins + "<br>" +

"Fish: " + player.fish + "<br>" +

"Biome: " + currentBiome + "<br>" +

"Island: " +
getCurrentIsland() +
"<br>" +

"Inventory: " +
player.inventory.length +
" items<br>" +

"Skill Points: " +
player.skillPoints;

}

// =========================
// GAME UPDATE
// =========================

function updateGame(){

movePlayer();

updateCamera();

updateBiome();

collectCoins();

collectLoot();

enemyCombat();

bossCombat();

updateStory();

unlockEndgame();

if(player.hp <= 0){

alert(
"Game Over!\n" +
"Level: " + player.level +
"\nCoins: " + player.coins
);

location.reload();

}

}

// =========================
// RENDER
// =========================

function render(){

drawWorld();

drawCoins();

drawLoot();

drawEnemies();

drawBosses();

drawPlayer();

updateUI();

}

// =========================
// MAIN LOOP
// =========================

function gameLoop(){

updateGame();

render();

requestAnimationFrame(
gameLoop
);

}

gameLoop();

</script>
</body>
</html>
