function useAbility(name){

const now = Date.now();

if(
now < cooldowns[name]
)
return;

cooldowns[name] =
now +
abilities[name].cooldown;

if(name === "dash"){

player.x += 250;

}

if(name === "bubbleBlast"){

for(
let enemy of enemies
){

enemy.hp -=
abilities.bubbleBlast.damage;

}

}

if(name === "electricShock"){

for(
let enemy of enemies
){

enemy.hp -=
abilities.electricShock.damage;

}

for(
let boss of bosses
){

boss.hp -=
abilities.electricShock.damage;

}

}

if(name === "whirlpool"){

for(
let enemy of enemies
){

enemy.hp -=
abilities.whirlpool.damage;

}

for(
