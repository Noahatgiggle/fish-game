// =========================
// COMBAT
// =========================

function enemyCombat(){

for(
let i=enemies.length-1;
i>=0;
i--
){

let enemy =
enemies[i];

let dx =
player.x - enemy.x;

let dy =
player.y - enemy.y;

let distance =
Math.hypot(dx,dy);

if(distance < 400){

enemy.x +=
(dx/distance) *
enemy.speed;

enemy.y +=
(dy/distance) *
enemy.speed;

}

if(distance < 40){

enemy.hp -=
player.damage;

player.hp -=
enemy.damage;

if(enemy.hp <= 0){

player.coins +=
enemy.reward;

gainXP(
enemy.reward * 2
);

randomLoot();

enemies.splice(i,1);

}

}

}

}

function bossCombat(){

for(
let i=bosses.length-1;
i>=0;
i--
){

let boss =
bosses[i];

let dx =
player.x - boss.x;

let dy =
player.y - boss.y;

let distance =
Math.hypot(dx,dy);

if(distance < 500){

boss.x +=
(dx/distance) * 1.5;

boss.y +=
(dy/distance) * 1.5;

}

if(distance < 80){

boss.hp -=
player.damage;

player.hp -=
boss.damage;

}

if(
boss.hp <
boss.maxHp * 0.75
)
boss.phase = 2;

if(
boss.hp <
boss.maxHp * 0.50
)
boss.phase = 3;

if(
boss.hp <
boss.maxHp * 0.25
)
boss.phase = 4;

if(boss.hp <= 0){

player.coins +=
1000;

gainXP(
500
);

const reward =
randomLoot();

alert(
boss.name +
" defeated!\nLoot: " +
reward
);

bosses.splice(i,1);

}

}

